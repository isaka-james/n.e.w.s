# =============================================================================
# N.E.W.S. environment configuration
# Copy this file to .env and fill in your own values.
# =============================================================================

# DeepSeek
# Sign up: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# NewsData.io (200 req/day free)
# Sign up: https://newsdata.io/register
NEWSDATA_API_KEY=your_newsdata_key_here

# NewsAPI.org (100 req/day free)
# Sign up: https://newsapi.org/register
NEWSAPI_API_KEY=your_newsapi_key_here

# NewsCatcher CatchAll (pay-as-you-go, 1 concurrent job on free plan)
# Sign up: https://www.newscatcherapi.com
NEWSCATCHER_API_KEY=your_newscatcher_key_here

# GNews (100 req/day free)
# Sign up: https://gnews.io/signup
GNEWS_API_KEY=your_gnews_key_here

# The Guardian (5000 req/day free, 12 req/sec)
# Sign up: https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=your_guardian_key_here

# New York Times (4000 req/day free)
# Sign up: https://developer.nytimes.com/accounts/create
NYTIMES_API_KEY=your_nytimes_key_here
NYTIMES_API_SECRET_KEY=your_nytimes_secret_here

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_long_random_hex_string

# Database
DATABASE_URL=postgresql://news_user:news_password@postgres:5432/news_system
POSTGRES_DB=news_system
POSTGRES_USER=news_user
POSTGRES_PASSWORD=news_password

# App URLs (defaults match docker-compose)
NEXT_PUBLIC_APP_URL=http://localhost:4291
NEXT_PUBLIC_API_URL=http://localhost:4291/api
